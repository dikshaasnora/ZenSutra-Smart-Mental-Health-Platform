# ============================================================
#  ZENSUTRA — Environment Variables
#  File: Backend/.env
#  ⚠️  NEVER commit this file to GitHub — add it to .gitignore
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── MONGODB ──────────────────────────────────────────────────
# Paste your MongoDB Atlas connection string below.
# Replace <username>, <password>, and <cluster> with your real values.
# Example: mongodb+srv://diksh:mypassword123@cluster0.abcde.mongodb.net/zensutra
MONGO_URI=mongodb+srv://dikshaasnora42_db_user:BiOs9lLhKn1RD6Jx@zensutra.5bf44pm.mongodb.net/zensutra?retryWrites=true&w=majority&appName=zensutra

# ── JWT AUTH ─────────────────────────────────────────────────
# This is the secret key used to sign login tokens.
# Use any long random string — the longer the better.
# DO NOT change this after users have registered or they will be logged out.
JWT_SECRET=ZenSutra_Super_Secret_Key_2026_abcdefghijklmnop_1234567890_XYZ!@#
JWT_EXPIRE=30d

# ── EMAIL (Gmail) ─────────────────────────────────────────────
# Used to send OTP verification emails and appointment confirmations.
# Use a Gmail App Password — NOT your real Gmail password.
# How to get App Password:
#   1. Go to myaccount.google.com/security
#   2. Turn on 2-Step Verification
#   3. Go to App Passwords → Select "Mail" → Generate
#   4. Copy the 16-character password and paste below
EMAIL_SERVICE=gmail
EMAIL_USERNAME=dikshaasnora42@gmail.com
EMAIL_PASSWORD=S45LiJvay-w@kpr
EMAIL_FROM=Zensutra <noreply@zensutra.app>

# ── FRONTEND URL (for CORS) ───────────────────────────────────
# The URL your frontend runs on.
# In development this is your local server.
FRONTEND_URL=http://localhost:5001

# ── GOOGLE GEMINI AI ─────────────────────────────────────────
# Powers the Zen AI chat feature.
# Get your free key at: https://aistudio.google.com/app/apikey
# If left blank, Zen AI will use rule-based fallback responses.
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ── PYTHON ML SERVICE (optional) ─────────────────────────────
# Only needed if you are running the Python face emotion model.
# You already have this running on port 8000.
ML_SERVICE_URL=http://localhost:8000/predict_emotion

# ── DEVELOPMENT HELPERS ───────────────────────────────────────
# DEV_OTP_BYPASS=true  → OTP will print in terminal instead of sending email
# USE_TEST_EMAIL=true  → Uses Ethereal fake email (no real email sent)
DEV_OTP_BYPASS=true
USE_TEST_EMAIL=false

# ── GOOGLE OAUTH ───────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID → Web application
# 2. Add Authorized JS origin:  http://localhost:5174
# 3. Add Authorized redirect URI: http://localhost:5174
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── MICROSOFT OAUTH ────────────────────────────────────────────
# Get from: https://portal.azure.com → App registrations → New registration
# 1. Supported account types: Accounts in any organizational directory + personal accounts
# 2. Redirect URI (SPA): http://localhost:5174
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here