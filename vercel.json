{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend-react/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*\\.[a-zA-Z0-9]+)$",
      "destination": "/frontend-react/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend-react/index.html"
    }
  ]
}
